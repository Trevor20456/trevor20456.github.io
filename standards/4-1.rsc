b:["$","section",null,{"className":"content-section artifact-section","aria-labelledby":"artifact-41","children":[["$","div",null,{"className":"section-heading","children":[["$","p",null,{"className":"eyebrow","children":"Course artifact · Indicator 4.1.d · Upcoming position"}],["$","h2",null,{"id":"artifact-41","children":"Trona High School Technology Recognition Plan"}],["$","p",null,{"children":"Because I have not yet begun my position at Trona High School, this artifact is intentionally a future-facing plan. It gives me a responsible process for learning what colleagues already do well before I recognize any individual by name."}]]}],["$","div",null,{"className":"artifact-grid","children":[["$","article",null,{"className":"artifact-card","children":[["$","p",null,{"className":"artifact-label","children":"Recognition plan"}],["$","h3",null,{"children":"Observe → Invite → Celebrate"}],["$","div",null,{"children":["$","p",null,{"children":"The plan identifies what high-impact technology practice will look like, how I will learn about it during onboarding and how educators will approve a spotlight before it is shared."}]}],["$","a",null,{"className":"text-link","href":"/artifacts/technology-leadership-spotlights","children":["Explore the artifact"," ",["$","span",null,{"aria-hidden":"true","children":"→"}]]}]]}],["$","article",null,{"className":"reflection-card","children":[["$","p",null,{"className":"artifact-label","children":"Alignment reflection"}],["$","h3",null,{"children":"Why this addresses 4.1.d"}],["$","p",null,{"children":"Standard 4.1.d asks coaches to recognize educators across an organization who use technology effectively for high-impact teaching and learning. My first step is to listen and observe; after onboarding, I will add educator-approved examples that other Trona colleagues can adapt."}]]}]]}]]}]
