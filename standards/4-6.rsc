9:["$","article","4.6.c",{"className":"indicator-card","children":[["$","span",null,{"children":"4.6.c"}],["$","h3",null,{"children":"Student ownership of data"}],["$","p",null,{"children":"Help educators empower students to use learning evidence to set goals and monitor progress."}]]}]
a:["$","section",null,{"className":"content-section artifact-section","aria-labelledby":"artifact-46","children":[["$","div",null,{"className":"section-heading","children":[["$","p",null,{"className":"eyebrow","children":"EDEL 518A artifact · Developing alignment with 4.6.a–c"}],["$","h2",null,{"id":"artifact-46","children":"Qualitative and Quantitative Data for Student Goal Setting"}],["$","p",null,{"children":"This two-page 12th-grade Government resource teaches students how to distinguish qualitative and quantitative evidence, interpret both in context, and turn one number plus one observation into a SMART goal."}]]}],["$","div",null,{"className":"artifact-grid","children":[["$","article",null,{"className":"artifact-card","children":[["$","p",null,{"className":"artifact-label","children":"EDEL 518A data project"}],["$","h3",null,{"children":"Data Guide and Goal-Setting Worksheet"}],["$","div",null,{"children":["$","p",null,{"children":"Page one defines the two data types and introduces the Notice–Ask–Act routine. Page two asks students to select one quantitative data point and one qualitative observation, plan supports, measure progress, and reflect."}]}],["$","a",null,{"className":"text-link","href":"/artifacts/data-informed-goal-setting/","children":["Explore the embedded project"," ",["$","span",null,{"aria-hidden":"true","children":"→"}]]}]]}],["$","article",null,{"className":"reflection-card","children":[["$","p",null,{"className":"artifact-label","children":"Sharing with colleagues"}],["$","h3",null,{"children":"A Ready-to-Adapt Student Routine"}],["$","p",null,{"children":"I will share this resource with colleagues as a short model for data conversations. Together, we can adapt the prompts to different subjects, decide which data are appropriate to collect, and protect student responses while using patterns to improve support."}]]}]]}]]}]
b:["$","section",null,{"className":"content-section focus-section","aria-labelledby":"alignment-46","children":[["$","div",null,{"className":"section-heading","children":[["$","p",null,{"className":"eyebrow","children":"Direct alignment · 4.6.a–c"}],["$","h2",null,{"id":"alignment-46","children":"How the Project Addresses Every Indicator"}]]}],["$","div",null,{"className":"indicator-grid compact-indicators","children":[["$","article",null,{"className":"indicator-card","children":[["$","span",null,{"children":"4.6.a"}],["$","h3",null,{"children":"Use Data Responsibly"}],["$","p",null,{"children":"The guide tells students and educators to look for patterns rather than labels, consider context such as language, access, health and responsibilities, ask what the numbers do not show, and use data to support growth. Student worksheets should be stored privately and discussed without publicizing personally identifiable information."}]]}],["$","article",null,{"className":"indicator-card","children":[["$","span",null,{"children":"4.6.b"}],["$","h3",null,{"children":"Combine Evidence for Decisions"}],["$","p",null,{"children":"Students pair a measurable result—such as a score, percentage, level or completed assignments—with a reflection about their learning. Notice–Ask–Act uses both forms of evidence to identify gaps, consider missing information, and choose an appropriate next step."}]]}],["$","article",null,{"className":"indicator-card","children":[["$","span",null,{"children":"4.6.c"}],["$","h3",null,{"children":"Build Student Ownership"}],["$","p",null,{"children":"Students use their own evidence to write a SMART goal, choose a strategy and support, define how success will be measured, and complete a check-in reflection. Monitoring progress and adjusting the plan become part of the learner’s work."}]]}]]}]]}]
