dren":"Data-Driven Decision-Maker"}],["$","div",null,{"className":"page-lede","children":[["$","p",null,{"children":"Coaches model and support responsible use of qualitative and quantitative evidence to guide instruction and professional learning."}],["$","a",null,{"className":"source-link","href":"https://iste.org/standards/coaches","target":"_blank","rel":"noreferrer","children":["Review the complete official standard ",["$","span",null,{"aria-hidden":"true","children":"↗"}]]}]]}]]}],["$","section",null,{"className":"content-section","aria-labelledby":"4-6-indicators","children":[["$","div",null,{"className":"section-heading","children":[["$","p",null,{"className":"eyebrow","children":"Standard overview"}],["$","h2",null,{"id":"4-6-indicators","children":"Indicators"}],["$","p",null,{"children":"Plain-language summaries are provided below. The official ISTE page remains the source of record."}]]}],["$","div",null,{"className":"indicator-grid","children":[["$","article","4.6.a",{"className":"indicator-card","children":[["$","span",null,{"children":"4.6.a"}],["$","h3",null,{"children":"Secure data practices"}],"$L7"]}],"$L8","$L9"]}]]}],["$La","$Lb"],"$Lc"]}]}],"$Ld"]}]
