4.4 and 4.7"}],["$","h1",null,{"children":"Distance Education & AUP Quick Brief"}],["$","div",null,{"className":"page-lede","children":["$","p",null,{"children":"This presentation translates a real district acceptable-use policy into practical guidance for distance education. It is used twice in this portfolio because the same work demonstrates different aspects of learning design and digital citizenship."}]}]]}],["$","section",null,{"className":"content-section artifact-showcase","aria-labelledby":"aup-artifact","children":[["$","div",null,{"className":"artifact-cover","role":"img","aria-label":"Distance Education and Acceptable Use Policy Quick Brief cover","children":["$","div",null,{"className":"portrait-placeholder","children":["$","span",null,{"aria-hidden":"true","children":"AUP"}]}]}],["$","div",null,{"className":"artifact-showcase-copy","children":[["$","p",null,{"className":"eyebrow","children":"Original presentation"}],["$","h2",null,{"id":"aup-artifact","children":"A Policy Made Usable"}],["$","p",null,{"children":"The brief focuses on Covina-Valley Unified School District’s Student Internet and Technology Acceptable Use guidance, revised in July 2025. It helps educators connect policy language to the everyday decisions students make in a distance-education environment."}],"$L7","$L8","$L9"]}]]}],"$La"]}]}],"$Lb"]}]
