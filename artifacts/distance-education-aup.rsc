a:["$","section",null,{"className":"content-section","aria-labelledby":"two-connections","children":[["$","div",null,{"className":"section-heading","children":[["$","p",null,{"className":"eyebrow","children":"One artifact · two standards"}],["$","h2",null,{"id":"two-connections","children":"How the Evidence Is Used"}]]}],["$","div",null,{"className":"two-column-content","children":[["$","article",null,{"className":"prose-card","children":[["$","p",null,{"className":"artifact-label","children":"Standard 4.4.a and 4.4.c"}],["$","h3",null,{"children":"Learning Designer"}],["$","p",null,{"children":"The brief grounds distance-education design in an authentic policy and gives educators a concise resource they can use when planning active online learning. Its segmented visual format also offers a more accessible entry point than asking learners to navigate a full policy document without guidance."}]]}],["$","article",null,{"className":"prose-card emphasis-card","children":[["$","p",null,{"className":"artifact-label","children":"Standard 4.7.d"}],["$","h3",null,{"children":"Digital Citizen Advocate"}],["$","p",null,{"children":"The presentation makes privacy and acceptable use part of instruction. It supports informed decisions about personal data and digital profiles instead of assuming students will understand those responsibilities simply because they use technology often."}]]}]]}]]}]
