7:["$","article",null,{"children":[["$","span",null,{"className":"spotlight-number","children":"01"}],["$","h3",null,{"children":"Observe and Listen"}],["$","p",null,{"className":"spotlight-role","children":"First 60 days"}],["$","p",null,{"children":"I will learn from school leaders, the district’s technology support, classroom observations and informal conversations. The goal is to understand what is already working instead of arriving with assumptions."}]]}]
