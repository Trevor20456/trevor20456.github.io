ndard 4.6"}],["$","h1",null,{"children":"Accessible Design Story Series"}],["$","div",null,{"className":"page-lede","children":["$","p",null,{"children":"A three-part visual resource showing how accessibility can be planned throughout an instructional-design process rather than added after a digital lesson is finished."}]}]]}],["$","section",null,{"className":"content-section","aria-labelledby":"story-series","children":[["$","div",null,{"className":"section-heading","children":[["$","p",null,{"className":"eyebrow","children":"Embedded artifact"}],["$","h2",null,{"id":"story-series","children":"CSUF-Inspired Story Series"}],["$","p",null,{"children":"The three original story pages are presented below as responsive, selectable text so the artifact remains readable with screen readers, keyboard navigation and text enlargement."}]]}],["$","div",null,{"className":"indicator-grid","children":[["$","article",null,{"className":"indicator-card","children":[["$","span",null,{"children":"Story 1"}],["$","h3",null,{"children":"Design for Access From the Start"}],"$L7"]}],"$L8","$L9"]}],"$La","$Lb"]}],"$Lc"]}]}],"$Ld"]}]
7:["$","p",null,{"children":"Use readable text, captions, descriptive structure, flexible participation, keyboard access and layouts that work on mobile devices."}]
