c:["$","section",null,{"className":"content-section focus-section","aria-labelledby":"sharing-plan-46","children":[["$","div",null,{"className":"section-heading","children":[["$","p",null,{"className":"eyebrow","children":"Sharing and evidence plan"}],["$","h2",null,{"id":"sharing-plan-46","children":"How I Will Share This With Colleagues"}]]}],["$","div",null,{"className":"two-column-content","children":[["$","article",null,{"className":"prose-card","children":[["$","h3",null,{"children":"Start with a useful self-check"}],["$","p",null,{"children":"I will share the story series during a short staff conversation or through a digital resource page, then invite colleagues to use its five checks on one lesson they already teach. This keeps the conversation practical and avoids turning accessibility into another abstract compliance task."}]]}],["$","article",null,{"className":"prose-card emphasis-card","children":[["$","h3",null,{"children":"Build honest evidence over time"}],["$","p",null,{"children":"I will collect voluntary feedback about which checks uncovered a barrier, what educators revised and how students responded. I will not collect student-identifying information. That evidence can later show how data were gathered securely, interpreted for design decisions and used to help learners identify supports that work for them."}]]}]]}]]}]
